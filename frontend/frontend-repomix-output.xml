  width: 100%;
  transition: color 0.2s;
}
.popup-abort-btn:hover { color: #ff6b6b; }

.popup-error {
  font-size: 0.73rem;
  color: #ff6b6b;
  letter-spacing: 0.08em;
  padding: 0.5rem 0.7rem;
