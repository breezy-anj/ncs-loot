}
.nav-btn.danger:hover {
  border-color: #ff4444;
  color: #ff4444;
  box-shadow: 0 0 10px rgba(255,68,68,0.2);
}

/* ═══════════════════════════════════════════════
   SPLASH SCREEN
═══════════════════════════════════════════════ */
.splash {
  position: fixed;
  inset: 0;
  background: var(--bg);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
}

.splash-title {
  font-family: var(--cinzel);
