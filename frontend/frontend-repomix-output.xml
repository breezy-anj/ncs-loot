<file path="src/index.css">
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --neon:       #00ff41;
  --neon-dim:   #00aa2b;
  --neon-glow:  rgba(0, 255, 65, 0.15);
  --bg:         #070a07;
  --bg-card:    rgba(0, 18, 4, 0.85);
  --border:     rgba(0, 255, 65, 0.25);
  --border-bright: rgba(0, 255, 65, 0.7);
  --text:       #c8ffd4;
  --text-dim:   #5a8c62;
  --mono:       'Share Tech Mono', 'Courier New', monospace;
  --cinzel:     'Cinzel', serif;
}

html { scroll-behavior: smooth; }

body {
  background-color: var(--bg);
  color: var(--text);
  font-family: var(--mono);
  overflow-x: hidden;
  min-height: 100vh;
}

/* ── Scrollbar ────────────────────────────────── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--neon-dim); border-radius: 3px; }

/* ── Utility ──────────────────────────────────── */
.cinzel { font-family: var(--cinzel); }

.neon-text {
  color: var(--neon);
  text-shadow: 0 0 8px var(--neon), 0 0 20px rgba(0, 255, 65, 0.4);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.2; }
}
.blink { animation: blink 1.2s step-end infinite; }

@keyframes scanline {
  0%   { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}
</file>

